@page "/"
@rendermode InteractiveServer

    @inject PredictService _predictService

    <PageTitle>Прогноз цены</PageTitle>

    <div class="card p-4 shadow">
        <h3>✈️ Поиск рейса</h3>
    <div class="row g-3">
        <!-- Первая строка: Города -->
        <div class="col-md-6">
            <label class="form-label">Откуда:</label>
            <input @bind="origin" @bind:event="oninput" list="myCities" class="form-control" placeholder="Город вылета" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Куда:</label>
            <input @bind="destination" @bind:event="oninput" list="myCities" class="form-control" placeholder="Город прилета" />
        </div>

        <!-- Вторая строка: Дата и Кнопка -->
        <div class="col-md-9">
            <label class="form-label">Дата вылета:</label>
            <input type="date" @bind="travelDate" class="form-control" />
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-primary w-100" @onclick="CalculatePrice  ">
                <i class="bi bi-search"></i> Рассчитать
            </button>
        </div>
    </div>
        <div class="row mt-5 justify-content-end"> 
        <div class="col-md-4"> 
            @if (popularRoutes != null && popularRoutes.Any())
            {
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body p-3">
                        <h6 class="card-title fw-bold text-primary mb-3">
                            <i class="bi bi-graph-up-arrow"></i> Топ направлений
                        </h6>
                        
                        <div class="list-group list-group-flush">
                            @foreach (var route in popularRoutes)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-0 border-bottom-0">
                                    <span style="font-size: 0.9rem;">
                                        <strong>@route.Origin</strong> → <strong>@route.Destination</strong>
                                    </span>
                                    <span class="badge bg-primary rounded-pill">@route.Count</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="text-center mt-5">
        <!-- Стилизованный заголовок -->
        <h1 class="display-4 text-uppercase" style="letter-spacing: 2px;">
            <span style="font-weight: 300;">Flight</span><span style="font-weight: 800;">Predict</span>
        </h1>

        <!-- Текст о сайте -->
        <div class="row justify-content-center">
            <div class="col-md-8">
                <p class="lead text-muted">
                    Наш сервис анализирует исторические данные и текущие предложения, чтобы помочь вам
                    <strong>спрогнозировать стоимость авиабилетов</strong>. Мы подскажем лучшее время
                    для покупки, чтобы вы могли спланировать свое путешествие максимально выгодно.
                </p>
            </div>
        </div>
    </div>
  
    @if (isCalculated)
    {
        @if (resultPrice > 0)
        {
            <div class="alert alert-success mt-4 shadow-sm">
                <h4 class="alert-heading">📊 Результат прогноза:</h4>
                <p class="display-6">@resultPrice.ToString("N2") ₽</p>
                <hr>
                <p class="mb-0"><strong>Совет:</strong> @advice</p>
            </div>
        }
        else
        {
            <div class="alert alert-danger mt-4 shadow-sm">
                <h4 class="alert-heading">⚠️ Ошибка</h4>
                <p>@advice</p> @* Здесь будет текст "Данные не найдены" *@
            </div>
        }
    }
    
        <datalist id="myCities">
            @if (availableCities != null)
            {
                @foreach (var code in availableCities)
                {
                    <option value="@(code)">@(code)</option>
                }
            }
        </datalist>
 
    </div>
    




@code {


    // Это ваша "Живая Вью-Модель" прямо внутри страницы

    private List<FlightListItem> flightListItems; 
    private List<string> availableCities = new();

    private DateTime travelDate = DateTime.Now.AddDays(7); // По умолчанию через неделю
    private string origin;
    private string destination;
    private bool isCalculated = false;


    private decimal resultPrice;
    private string advice;

    protected override void OnInitialized()
    {
        flightListItems = _predictService.GetFlightsLists().ToList();


        availableCities = flightListItems
            .Select(f => f.Original)
            .Union(flightListItems.Select(f => f.Destination))
            .Distinct()
            .OrderBy(c => c)
            .ToList();

        // resultPrice = res.Price;
        // advice = res.Advice;
    }
    protected void CalculatePrice()
    {
        isCalculated = false;


        (resultPrice, advice) = _predictService.PredictPrice(origin, destination, travelDate);
        isCalculated = true;
        if (resultPrice != 0) CalculateStat();
        
        StateHasChanged();
        }
    public class RouteStat
    {
        public string Origin { get; set; }
        public string Destination { get; set; }
        public int Count { get; set; }
    }

    // Хранилище всех запросов и список для вывода ТОП-3
    private List<RouteStat> allStats = new();
    private List<RouteStat> popularRoutes = new();

    private void CalculateStat()
    {
        // 1. Простейшая проверка на пустые поля
        if (string.IsNullOrWhiteSpace(origin) || string.IsNullOrWhiteSpace(destination))
            return;

        // 2. Ищем, был ли уже такой маршрут (игнорируя регистр букв)
        var existing = allStats.FirstOrDefault(r =>
            r.Origin.Trim().Equals(origin.Trim(), StringComparison.OrdinalIgnoreCase) &&
            r.Destination.Trim().Equals(destination.Trim(), StringComparison.OrdinalIgnoreCase));

        if (existing != null)
        {
            // Если нашли — просто увеличиваем счетчик
            existing.Count++;
        }
        else
        {
            // Если новый — добавляем в общий список
            allStats.Add(new RouteStat
            {
                Origin = origin.Trim(),
                Destination = destination.Trim(),
                Count = 1
            });
        }

        // 3. Обновляем топ-3 по количеству кликов
        popularRoutes = allStats
            .OrderByDescending(r => r.Count)
            .Take(3)
            .ToList();

        // Здесь можно добавить вызов вашего метода самого расчета (API и т.д.)
    }
    }
  
